{
  "name": "imba97-blog-vite",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@11.5.0",
  "scripts": {
    "dev": "vite",
    "build": "cross-env NODE_ENV=production vite-ssg build && esno ./scripts/copy-fonts.ts && esno ./scripts/rss.ts",
    "generate-rss": "esno scripts/rss.ts",
    "post:new": "esno scripts/create-post.ts",
    "generate-search-index": "esno scripts/search-index-cli.ts",
    "preview": "vite preview",
    "install:stable": "pnpm dlx esno ./scripts/pnpm-stable-install.ts",
    "env:check": "pnpm dlx esno ./scripts/pnpm-env-check.ts",
    "lint": "eslint .",
    "prepare": "simple-git-hooks"
  },
  "dependencies": {
    "@unhead/vue": "^3.1.1",
    "@unocss/reset": "^66.7.0",
    "@vueuse/core": "^14.3.0",
    "dayjs": "^1.11.21",
    "floating-vue": "^5.2.2",
    "matter-attractors": "^0.1.6",
    "matter-js": "^0.20.0",
    "minisearch": "^7.2.0",
    "motion-v": "^2.2.1",
    "nprogress": "^0.2.0",
    "pinia": "^3.0.4",
    "shiki": "^4.1.0",
    "shiki-magic-move": "^1.3.2",
    "twikoo": "^1.7.11",
    "vue": "^3.5.35",
    "vue-router": "^5.1.0",
    "vue-router-better-scroller": "^0.0.0"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^9.0.0",
    "@iconify/json": "^2.2.481",
    "@octokit/rest": "^22.0.1",
    "@shikijs/markdown-it": "^4.1.0",
    "@shikijs/transformers": "^4.1.0",
    "@shikijs/twoslash": "^4.1.0",
    "@types/diacritics": "^1.3.3",
    "@types/markdown-it": "^14.1.2",
    "@types/markdown-it-link-attributes": "^3.0.5",
    "@types/node": "^25.9.1",
    "@types/nprogress": "^0.2.3",
    "@unocss/eslint-plugin": "^66.7.0",
    "@unocss/preset-web-fonts": "^66.7.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/tsconfig": "^0.9.1",
    "cross-env": "^10.1.0",
    "diacritics": "^1.3.0",
    "eslint": "^10.4.1",
    "esno": "^4.8.0",
    "feed": "^5.2.1",
    "gray-matter": "^4.0.3",
    "markdown-it": "^14.2.0",
    "markdown-it-anchor": "^9.2.0",
    "markdown-it-extra-link": "^0.3.0",
    "markdown-it-github-alerts": "^1.0.1",
    "markdown-it-link-attributes": "^4.0.1",
    "markdown-it-table-of-contents": "^1.2.0",
    "nano-staged": "^1.0.2",
    "pathe": "^2.0.3",
    "sass-embedded": "^1.100.0",
    "simple-git-hooks": "^2.13.1",
    "tinyglobby": "^0.2.16",
    "typescript": "^6.0.3",
    "uno-colors": "^0.1.0",
    "unocss": "^66.7.0",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-vue-components": "^32.1.0",
    "unplugin-vue-markdown": "^32.0.0",
    "vite": "^8.0.14",
    "vite-plugin-inspect": "^11.4.1",
    "vite-plugin-optimize-exclude": "^0.0.1",
    "vite-ssg": "^28.3.0"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm exec nano-staged"
  },
  "nano-staged": {
    "*.{js,jsx,cjs,mjs,ts,tsx,cts,mts,vue,md,mdx}": "eslint --fix"
  }
}
